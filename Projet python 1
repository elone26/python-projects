print("Bienvenue sur mon programme de cours de maths ou je viens résolver mes problèmes de maths et résoudre les formules : aujourd'hui, on se base sur le pourcentage")
print("1. Calculer la valeur de départ")
print("2. Calculer la valeur d'arrivée")
print("3. Calculer le pourcentage")
choix = input("Choisissez parmi les 3 propositions en répondant par 1,2,3 : ")
if choix == "1":
    print("Très bien, nous allons calculer ta valeur de départ")
    va = float(input("Entre ta valeur d'arrivée : "))
    pourcentage = float(input("Entre le pourcentage : "))
    vd = va/ (1 + ( pourcentage / 100))
    print("Voici ta valeur de départ :" , round(vd , 2 ))
    print("J'espère que l'on a été utile à toi")
elif choix == "2":
    print("Très bien, nous allons calculer ta valeur d'arrivée !")
    vd = float(input("Entre ta valeur de départ : "))
    pourcentage = float(input("Entre le pourcentage : "))
    va = vd * (1 + ( pourcentage/100))
    print("Ta valeur d'arrivé est :", round(va , 2))
    print("J'espère que tu peux maintenant terminer ton exo : la prochaine fois n'oublie pas ta calculette !")
elif choix== "3":
    print("Très bien, nous allons calculer le pourcentage !")
    vd = float(input("Entre ta valeur de départ :"))
    va = float(input("Entre ta valeur d'arrivée :"))
    pourcentage = (va/vd) - 1
    print("Ton pourcentage est, roulement de tembours,","c'est :" , round(pourcentage , 2))
    print("J'espère que tu as aimé mon programme et que tu reviendras très prochainement !")
    print("Merci")
else: 
    print("Je crois que tu t'es trompé de numéro -_- !")
